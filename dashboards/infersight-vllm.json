{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "InferSight — LLM Inference",
  "uid": "infersight-vllm",
  "tags": ["infersight", "vllm", "llm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": null,
        "query": "label_values(infersight_requests_total, model)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries", "title": "TTFT — P50 / P90 / P99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(infersight_ttft_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p50 {{model}}" },
        { "expr": "histogram_quantile(0.90, sum(rate(infersight_ttft_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p90 {{model}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(infersight_ttft_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p99 {{model}}" }
      ]
    },
    {
      "type": "timeseries", "title": "Time between tokens — P50 / P99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(infersight_tbt_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p50 {{model}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(infersight_tbt_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p99 {{model}}" }
      ]
    },
    {
      "type": "timeseries", "title": "End-to-end latency — P50 / P99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(infersight_e2e_latency_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p50 {{model}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(infersight_e2e_latency_seconds_bucket{model=~\"$model\"}[5m])) by (le, model))", "legendFormat": "p99 {{model}}" }
      ]
    },
    {
      "type": "timeseries", "title": "Throughput — requests/s and tokens/s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(infersight_requests_total{model=~\"$model\"}[1m])) by (model)", "legendFormat": "req/s {{model}}" },
        { "expr": "sum(rate(infersight_completion_tokens_total{model=~\"$model\"}[1m])) by (model)", "legendFormat": "tokens/s {{model}}" }
      ]
    },
    {
      "type": "gauge", "title": "KV-cache usage",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.75 },
            { "color": "red", "value": 0.92 }
          ] }
        },
        "overrides": []
      },
      "targets": [ { "expr": "max(infersight_kv_cache_usage_ratio)", "legendFormat": "kv cache" } ]
    },
    {
      "type": "timeseries", "title": "Scheduler queue depth",
      "gridPos": { "h": 7, "w": 9, "x": 6, "y": 16 },
      "targets": [ { "expr": "sum(infersight_queue_depth) by (state)", "legendFormat": "{{state}}" } ]
    },
    {
      "type": "timeseries", "title": "In-flight requests & error rate",
      "gridPos": { "h": 7, "w": 9, "x": 15, "y": 16 },
      "targets": [
        { "expr": "sum(infersight_requests_in_flight)", "legendFormat": "in flight" },
        { "expr": "sum(rate(infersight_requests_total{status!~\"2..\"}[5m])) / clamp_min(sum(rate(infersight_requests_total[5m])), 1e-9)", "legendFormat": "error ratio" }
      ]
    }
  ]
}
